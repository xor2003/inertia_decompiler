snake.asm
                                ;*******************************************************************************************************************
                                ;                                              Snake Game By                                                       *
                                ;                                                 HERO-DAI                                                         *
                                ;*******************************************************************************************************************

                                ;code is not well-commented, sorry about that, I'll try to comment it nice and well, but can't make any
                                ;promises, Also, this code writes directly into the video memory instead of int 21H (21H is slow) except
                                ;at some certain points (like displaying scores and the intro)

                                ;and next time someone tells you to not use goto, ask them to code in assembly without goto... :P

 = 0                            left equ 0
 = 2                            top equ 2
 = F                            row equ 15
 = 28                           col equ 40
 = 28                           right equ left+col
 = 11                           bottom equ top+row

                                .model small
00000000                        data segment
00000000  57656C636F6D652074        msg db "Welcome to the snake game!!",0
0000001C  0A0D55736520612C20        instructions db 0AH,0DH,"Use a, s, d and w to control your snake",0AH,0DH,"Use q anytime to quit",0DH,0AH, "Press any key to continue$"
00000078  5468616E6B7320666F        quitmsg db "Thanks for playing! hope you enjoyed",0
0000009D  4F4F5053212120796F        gameovermsg db "OOPS!! your snake died! :P ", 0
000000B9  53636F72653A2000          scoremsg db "Score: ",0
000000C1  5E0A0A                    head db '^',10,10
000000C4  2A0A0B000000000000        body db '*',10,11, 3*15 DUP(0)
000000F4  01                        segmentcount db 1
000000F5  01                        fruitactive db 1
000000F6  08                        fruitx db 8
000000F7  08                        fruity db 8
000000F8  00                        gameover db 0
000000F9  00                        quit db 0   
000000FA  05                        delaytime db 5
000000FB                        data ends

00000000                        text segment
00000000                        main proc far
                                	assume ds: data, es: nothing
00000000  B80000                	mov ax, data
00000003  8ED8                  	mov ds, ax 
                                	
00000005  B800B8                	mov ax, 0b800H
00000008  8EC0                  	mov es, ax
                                	
                                	;clearing the screen
0000000A  B80300                	mov ax, 0003H
0000000D  CD10                  	int 10H
                                	
0000000F  8D1E0000              	lea bx, msg
00000013  BA0000                	mov dx,00
00000016  E80B03                	call writestringat
                                	
00000019  8D160000              	lea dx, instructions
0000001D  B409                  	mov ah, 09H
0000001F  CD21                  	int 21h
                                	
00000021  B407                  	mov ah, 07h
00000023  CD21                  	int 21h
00000025  B80300                	mov ax, 0003H
00000028  CD10                  	int 10H
0000002A  E87202                    call printbox      
                                    
                                    
0000002D                        mainloop:       
0000002D  E86200                    call delay             
00000030  8D1E0000                  lea bx, msg
00000034  BA0000                    mov dx, 00
00000037  E8EA02                    call writestringat
0000003A  E8B901                    call shiftsnake
0000003D  803E000001                cmp gameover,1
00000042  7412                      je gameover_mainloop
                                    
00000044  E85501                    call keyboardfunctions
00000047  803E000001                cmp quit, 1
0000004C  7421                      je quitpressed_mainloop
0000004E  E85200                    call fruitgeneration
00000051  E8F600                    call draw
                                    
                                    ;TODO: check gameover and quit
                                    
00000054  EBD7                      jmp mainloop
                                    
00000056                        gameover_mainloop: 
00000056  B80300                    mov ax, 0003H
00000059  CD10                  	int 10H
0000005B  C606000064                mov delaytime, 100
00000060  BA0000                    mov dx, 0000H
00000063  8D1E0000                  lea bx, gameovermsg
00000067  E8BA02                    call writestringat
0000006A  E82500                    call delay    
0000006D  EB19                      jmp quit_mainloop    
                                    
0000006F                        quitpressed_mainloop:
0000006F  B80300                    mov ax, 0003H
00000072  CD10                  	int 10H    
00000074  C606000064                mov delaytime, 100
00000079  BA0000                    mov dx, 0000H
0000007C  8D1E0000                  lea bx, quitmsg
00000080  E8A102                    call writestringat
00000083  E80C00                    call delay    
00000086  EB00                      jmp quit_mainloop    

                                    
                                    

00000088                        quit_mainloop:
                                ;first clear screen
00000088  B80300                mov ax, 0003H
0000008B  CD10                  int 10h    
0000008D  B8004C                mov ax, 4c00h
00000090  CD21                  int 21h  


00000092                        main endp
                                         


00000092                        delay proc 
                                    
                                    ;this procedure uses 1A interrupt, more info can be found on   
                                    ;http://www.computing.dcu.ie/~ray/teaching/CA296/notes/8086_bios_and_dos_interrupts.html
00000092  B400                      mov ah, 00
00000094  CD1A                      int 1Ah
00000096  8BDA                      mov bx, dx
                                    
00000098                        jmp_delay:
00000098  CD1A                      int 1Ah
0000009A  2BD3                      sub dx, bx
                                    ;there are about 18 ticks in a second, 10 ticks are about enough
0000009C  3A160000                  cmp dl, delaytime                                                      
000000A0  7CF6                      jl jmp_delay    
000000A2                            ret
                                    
000000A3                        delay endp
                                   
                                   


000000A3                        fruitgeneration proc
000000A3  8A2E0000                  mov ch, fruity
000000A7  8A0E0000                  mov cl, fruitx
000000AB                        regenerate:
                                    
000000AB  803E000001                cmp fruitactive, 1
000000B0  746F                      je ret_fruitactive
000000B2  B400                      mov ah, 00
000000B4  CD1A                      int 1Ah
                                    ;dx contains the ticks
000000B6  52                        push dx
000000B7  8BC2                      mov ax, dx
000000B9  33D2                      xor dx, dx
000000BB  32FF                      xor bh, bh
000000BD  B30F                      mov bl, row
000000BF  FECB                      dec bl
000000C1  F7F3                      div bx
000000C3  88160000                  mov fruity, dl
000000C7  FE060000                  inc fruity
                                    
                                    
000000CB  58                        pop ax
000000CC  B328                      mov bl, col
000000CE  FECA                      dec dl
000000D0  32FF                      xor bh, bh
000000D2  33D2                      xor dx, dx
000000D4  F7F3                      div bx
000000D6  88160000                  mov fruitx, dl
000000DA  FE060000                  inc fruitx
                                    
000000DE  380E0000                  cmp fruitx, cl
000000E2  7508                      jne nevermind
000000E4  382E0000                  cmp fruity, ch
000000E8  7502                      jne nevermind
000000EA  EBBF                      jmp regenerate             
000000EC                        nevermind:
000000EC  A00000                    mov al, fruitx
000000EF  D0C8                      ror al,1
000000F1  72B8                      jc regenerate
                                    
                                    
000000F3  8006000002                add fruity, top
000000F8  8006000000                add fruitx, left 
                                    
000000FD  8A360000                  mov dh, fruity
00000101  8A160000                  mov dl, fruitx
00000105  E8F101                    call readcharat
00000108  80FB2A                    cmp bl, '*'
0000010B  749E                      je regenerate
0000010D  80FB5E                    cmp bl, '^'
00000110  7499                      je regenerate
00000112  80FB3C                    cmp bl, '<'
00000115  7494                      je regenerate
00000117  80FB3E                    cmp bl, '>'
0000011A  748F                      je regenerate
0000011C  80FB76                    cmp bl, 'v'
0000011F  748A                      je regenerate    
                                    
00000121                        ret_fruitactive:
00000121                            ret
00000122                        fruitgeneration endp


00000122                        dispdigit proc
00000122  80C230                    add dl, '0'
00000125  B402                      mov ah, 02H
00000127  CD21                      int 21H
00000129                            ret
0000012A                        dispdigit endp   
                                   
0000012A                        dispnum proc    
0000012A  85C0                      test ax,ax
0000012C  7410                      jz retz
0000012E  33D2                      xor dx, dx
                                    ;ax contains the number to be displayed
                                    ;bx must contain 10
00000130  BB0A00                    mov bx,10
00000133  F7F3                      div bx
                                    ;dispnum ax first.
00000135  52                        push dx
00000136  E8F1FF                    call dispnum  
00000139  5A                        pop dx
0000013A  E8E5FF                    call dispdigit
0000013D                            ret
0000013E                        retz:
0000013E  B402                      mov ah, 02  
00000140                            ret    
00000141                        dispnum endp   



                                ;sets the cursor position, ax and bx used, dh=row, dl = column
                                ;preserves other registers
00000141                        setcursorpos proc
00000141  B402                      mov ah, 02H
00000143  53                        push bx
00000144  B700                      mov bh,0
00000146  CD10                      int 10h
00000148  5B                        pop bx
00000149                            ret
0000014A                        setcursorpos endp



0000014A                        draw proc
0000014A  8D1E0000                  lea bx, scoremsg
0000014E  BA0901                    mov dx, 0109h
00000151  E8D001                    call writestringat
                                    
                                    
00000154  83C207                    add dx, 7
00000157  E8E7FF                    call setcursorpos
0000015A  A00000                    mov al, segmentcount
0000015D  FEC8                      dec al
0000015F  32E4                      xor ah, ah
00000161  E8C6FF                    call dispnum
                                        
00000164  8D360000                  lea si, head
00000168                        draw_loop:
00000168  8A1C                      mov bl, ds:[si]
0000016A  84DB                      test bl, bl
0000016C  740B                      jz out_draw
0000016E  8B5401                    mov dx, ds:[si+1]
00000171  E85A01                    call writecharat
00000174  83C603                    add si,3   
00000177  EBEF                      jmp draw_loop 

00000179                        out_draw:
00000179  B346                      mov bl, 'F'
0000017B  8A360000                  mov dh, fruity
0000017F  8A160000                  mov dl, fruitx
00000183  E84801                    call writecharat
00000186  C606000001                mov fruitactive, 1
                                    
0000018B                            ret
                                    
                                    
                                    
0000018C                        draw endp



                                ;dl contains the ascii character if keypressed, else dl contains 0
                                ;uses dx and ax, preserves other registers
0000018C                        readchar proc
0000018C  B401                      mov ah, 01H
0000018E  CD16                      int 16H
00000190  7503                      jnz keybdpressed
00000192  32D2                      xor dl, dl
00000194                            ret
00000195                        keybdpressed:
                                    ;extract the keystroke from the buffer
00000195  B400                      mov ah, 00H
00000197  CD16                      int 16H
00000199  8AD0                      mov dl,al
0000019B                            ret


0000019C                        readchar endp                    
                                         
                                         
                                         
                                                  
                                                    


0000019C                        keyboardfunctions proc
                                    
0000019C  E8EDFF                    call readchar
0000019F  80FA00                    cmp dl, 0
000001A2  7447                      je next_14
                                    
                                    ;so a key was pressed, which key was pressed then solti?
000001A4  80FA77                    cmp dl, 'w'
000001A7  750D                      jne next_11
000001A9  803E000076                cmp head, 'v'
000001AE  743B                      je next_14
000001B0  C60600005E                mov head, '^'
000001B5                            ret
000001B6                        next_11:
000001B6  80FA73                    cmp dl, 's'
000001B9  750D                      jne next_12
000001BB  803E00005E                cmp head, '^'
000001C0  7429                      je next_14
000001C2  C606000076                mov head, 'v'
000001C7                            ret
000001C8                        next_12:
000001C8  80FA61                    cmp dl, 'a'
000001CB  750D                      jne next_13
000001CD  803E00003E                cmp head, '>'
000001D2  7417                      je next_14
000001D4  C60600003C                mov head, '<'
000001D9                            ret
000001DA                        next_13:
000001DA  80FA64                    cmp dl, 'd'
000001DD  750C                      jne next_14
000001DF  803E00003C                cmp head, '<'
000001E4  7405                      je next_14
000001E6  C60600003E                mov head,'>'
000001EB                        next_14:    
000001EB  80FA71                    cmp dl, 'q'
000001EE  7401                      je quit_keyboardfunctions
000001F0                            ret    
000001F1                        quit_keyboardfunctions:   
                                    ;conditions for quitting in here please  
000001F1  FE060000                  inc quit
000001F5                            ret
                                    
000001F6                        keyboardfunctions endp


                                                    
                                                    
                                                    
                                                    
                                                    
                                                    
000001F6                        shiftsnake proc     
000001F6  BB0000                    mov bx, offset head
                                    
                                    ;determine the where should the head go solti?
                                    ;preserve the head
000001F9  33C0                      xor ax, ax
000001FB  8A07                      mov al, [bx]
000001FD  50                        push ax
000001FE  43                        inc bx
000001FF  8B07                      mov ax, [bx]
00000201  43                        inc bx    
00000202  43                        inc bx
00000203  33C9                      xor cx, cx
00000205                        l:      
00000205  8B37                      mov si, [bx]
00000207  8537                      test si, [bx]
00000209  740C                      jz outside
0000020B  41                        inc cx     
0000020C  43                        inc bx
0000020D  8B17                      mov dx,[bx]
0000020F  8907                      mov [bx], ax
00000211  8BC2                      mov ax,dx
00000213  43                        inc bx
00000214  43                        inc bx
00000215  EBEE                      jmp l
                                    
00000217                        outside:    
                                    
                                    
                                    ;hopefully, the snake will be shifted, i.e. moved.
                                    ;now shift the head in its proper direction and then clear the last segment. 
                                    ;But don't clear the last segment if the snake has eaten the fruit
00000217  58                        pop ax
                                    ;al contains the snake head direction
                                    
00000218  52                        push dx
                                    ;dx now consists the coordinates of the last segment, we can use this to clear it
                                    
                                    
00000219  8D1E0000                  lea bx, head
0000021D  43                        inc bx
0000021E  8B17                      mov dx, [bx]
                                    
00000220  3C3C                      cmp al, '<'
00000222  7506                      jne next_1
00000224  FECA                      dec dl
00000226  FECA                      dec dl
00000228  EB14                      jmp done_checking_the_head
0000022A                        next_1:
0000022A  3C3E                      cmp al, '>'
0000022C  7506                      jne next_2                
0000022E  FEC2                      inc dl 
00000230  FEC2                      inc dl
00000232  EB0A                      jmp done_checking_the_head
                                    
00000234                        next_2:
00000234  3C5E                      cmp al, '^'
00000236  7504                      jne next_3 
00000238  FECE                      dec dh               
                                                   
                                    
0000023A  EB02                      jmp done_checking_the_head
                                    
0000023C                        next_3:
                                    ;must be 'v'
0000023C  FEC6                      inc dh
                                    
0000023E                        done_checking_the_head:    
0000023E  8917                      mov [bx],dx
                                    ;dx contains the new position of the head, now check whats in that position   
00000240  E8B600                    call readcharat ;dx
                                    ;bl contains the result
                                    
00000243  80FB46                    cmp bl, 'F'
00000246  7429                      je i_ate_fruit
                                    
                                    ;if fruit was not eaten, then clear the last segment, 
                                    ;it will be cleared where?
00000248  8BCA                      mov cx, dx
0000024A  5A                        pop dx 
0000024B  80FB2A                    cmp bl, '*'    ;the snake bit itself, gameover
0000024E  741C                      je game_over
00000250  B300                      mov bl, 0
00000252  E87900                    call writecharat
00000255  8BD1                      mov dx, cx
                                    
                                    
                                    
                                    
                                    
                                    ;check whether the snake is within the boundary
00000257  80FE02                    cmp dh, top
0000025A  7410                      je game_over
0000025C  80FE11                    cmp dh, bottom
0000025F  740B                      je game_over
00000261  80FA00                    cmp dl,left
00000264  7406                      je game_over
00000266  80FA28                    cmp dl, right
00000269  7401                      je game_over
                                    
                                    
                                    
                                    ;balance the stack, number of segment and the coordinate of the last segment
                                    
0000026B                            ret
0000026C                        game_over:
0000026C  FE060000                  inc gameover
00000270                            ret
00000271                        i_ate_fruit:    

                                    ; add a new segment then
00000271  A00000                    mov al, segmentcount
00000274  32E4                      xor ah, ah
                                    
                                    
00000276  8D1E0000                  lea bx, body
0000027A  B90300                    mov cx, 3
0000027D  F7E1                      mul cx
                                    
0000027F  5A                        pop dx
00000280  03D8                      add bx, ax
00000282  C6072A                    mov byte ptr ds:[bx], '*'
00000285  895701                    mov [bx+1], dx
00000288  FE060000                  inc segmentcount 
0000028C  8A360000                  mov dh, fruity
00000290  8A160000                  mov dl, fruitx
00000294  B300                      mov bl, 0
00000296  E83500                    call writecharat
00000299  C606000000                mov fruitactive, 0   
0000029E                            ret 
0000029F                        shiftsnake endp
                                   
                                   
                                                               
                                                               
                                                               
                                                               
                                                               
                                                               
                                                               
                                                               
                                                               
                                   
                                         
                                ;Printbox
0000029F                        printbox proc
                                ;Draw a box around
0000029F  B602                      mov dh, top
000002A1  B200                      mov dl, left
000002A3  B92800                    mov cx, col
000002A6  B32A                      mov bl, '*'
000002A8                        l1:                 
000002A8  E82300                    call writecharat
000002AB  FEC2                      inc dl
000002AD  E2F9                      loop l1
                                    
000002AF  B90F00                    mov cx, row
000002B2                        l2:
000002B2  E81900                    call writecharat
000002B5  FEC6                      inc dh
000002B7  E2F9                      loop l2
                                    
000002B9  B92800                    mov cx, col
000002BC                        l3:
000002BC  E80F00                    call writecharat
000002BF  FECA                      dec dl
000002C1  E2F9                      loop l3

000002C3  B90F00                    mov cx, row     
000002C6                        l4:
000002C6  E80500                    call writecharat    
000002C9  FECE                      dec dh 
000002CB  E2F9                      loop l4    
                                    
000002CD                            ret
000002CE                        printbox endp
                                              
                                              
                                              
                                              
                                              
                                              
                                              
                                              
                                              
                                ;dx contains row, col
                                ;bl contains the character to write
                                ;uses di. 
000002CE                        writecharat proc
                                    ;80x25
000002CE  52                        push dx
000002CF  8BC2                      mov ax, dx
000002D1  2500FF                    and ax, 0FF00H
000002D4  D1E8                      shr ax,1
000002D6  D1E8                      shr ax,1
000002D8  D1E8                      shr ax,1
000002DA  D1E8                      shr ax,1
000002DC  D1E8                      shr ax,1
000002DE  D1E8                      shr ax,1
000002E0  D1E8                      shr ax,1
000002E2  D1E8                      shr ax,1
                                    
                                    
000002E4  53                        push bx
000002E5  B7A0                      mov bh, 160
000002E7  F6E7                      mul bh 
000002E9  5B                        pop bx
000002EA  81E2FF00                  and dx, 0FFH
000002EE  D1E2                      shl dx,1
000002F0  03C2                      add ax, dx
000002F2  8BF8                      mov di, ax
000002F4  26881D                    mov es:[di], bl
000002F7  5A                        pop dx
000002F8                            ret    
000002F9                        writecharat endp
                                            
                                            
                                            
                                            
                                            
                                            
                                            
                                            
                                            
                                ;dx contains row,col
                                ;returns the character at bl
                                ;uses di
000002F9                        readcharat proc
000002F9  52                        push dx
000002FA  8BC2                      mov ax, dx
000002FC  2500FF                    and ax, 0FF00H
000002FF  D1E8                      shr ax,1
00000301  D1E8                      shr ax,1
00000303  D1E8                      shr ax,1
00000305  D1E8                      shr ax,1
00000307  D1E8                      shr ax,1
00000309  D1E8                      shr ax,1
0000030B  D1E8                      shr ax,1
0000030D  D1E8                      shr ax,1    
0000030F  53                        push bx
00000310  B7A0                      mov bh, 160
00000312  F6E7                      mul bh 
00000314  5B                        pop bx
00000315  81E2FF00                  and dx, 0FFH
00000319  D1E2                      shl dx,1
0000031B  03C2                      add ax, dx
0000031D  8BF8                      mov di, ax
0000031F  268A1D                    mov bl,es:[di]
00000322  5A                        pop dx
00000323                            ret
00000324                        readcharat endp        








                                ;dx contains row, col
                                ;bx contains the offset of the string
00000324                        writestringat proc
00000324  52                        push dx
00000325  8BC2                      mov ax, dx
00000327  2500FF                    and ax, 0FF00H
0000032A  D1E8                      shr ax,1
0000032C  D1E8                      shr ax,1
0000032E  D1E8                      shr ax,1
00000330  D1E8                      shr ax,1
00000332  D1E8                      shr ax,1
00000334  D1E8                      shr ax,1
00000336  D1E8                      shr ax,1
00000338  D1E8                      shr ax,1
                                    
0000033A  53                        push bx
0000033B  B7A0                      mov bh, 160
0000033D  F6E7                      mul bh
                                    
0000033F  5B                        pop bx
00000340  81E2FF00                  and dx, 0FFH
00000344  D1E2                      shl dx,1
00000346  03C2                      add ax, dx
00000348  8BF8                      mov di, ax
0000034A                        loop_writestringat:
                                    
0000034A  8A07                      mov al, [bx]
0000034C  84C0                      test al, al
0000034E  7408                      jz exit_writestringat
00000350  268805                    mov es:[di], al
00000353  47                        inc di
00000354  47                        inc di
00000355  43                        inc bx
00000356  EBF2                      jmp loop_writestringat
                                    
                                    
00000358                        exit_writestringat:
00000358  5A                        pop dx
00000359                            ret
                                    
                                    
0000035A                        writestringat endp
                                     
                                     
                                     
                                     
                                     
0000035A                        text ends          
                                end main


